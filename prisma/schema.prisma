// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model NovelProject {
  id              String    @id @default(cuid())
  spark           String    // 用户输入的灵感关键词
  title           String    @default("未命名项目") // 书名
  synopsis        String?   // 一句话简介
  goldenFinger    String?   // 核心金手指（力量体系）
  worldBackground String?   // 世界观背景
  tags            String?   // 作品标签（逗号分隔）
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  characters      Character[]
  worldRules      WorldRule[]
  volumes         Volume[]
  plotLines       PlotLine[]
}

model Character {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  role        String  @default("主角") // 主角/反派/配角
  personality String? // 性格特质
  background  String? // 背景档案
  conflict    String? // 冲突描述
  project     NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model WorldRule {
  id        String  @id @default(cuid())
  projectId String
  category  String  @default("基础规则") // 规则分类
  title     String
  content   String
  project   NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Hierarchical Outline Structure: 卷 → 阶段 → 单元 → 章 ───

model Volume {
  id        String   @id @default(cuid())
  projectId String
  order     Int      @default(0)
  title     String   @default("未命名卷")
  summary   String?
  stages    Stage[]
  project   NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Stage {
  id        String   @id @default(cuid())
  volumeId  String
  order     Int      @default(0)
  title     String   @default("未命名阶段")
  summary   String?
  units     Unit[]
  volume    Volume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)

  @@index([volumeId])
}

model Unit {
  id           String   @id @default(cuid())
  stageId      String
  order        Int      @default(0)
  title        String   @default("未命名单元")
  summary      String?
  chapterPlan  String?  // JSON: 单元章节规划
  chapters     Chapter[]
  stage        Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId])
}

model Chapter {
  id         String      @id @default(cuid())
  unitId     String
  projectId  String      // Keep for easy project-level queries
  order      Int         @default(0)
  title      String      @default("未命名章节")
  summary    String?
  content    String?     @default("")
  plotPoints String?     // JSON: 章节剧情要点列表
  wordCount  Int         @default(0)
  status     String      @default("draft") // draft/planned/completed
  unit       Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  storyBeats StoryBeat[]

  @@index([unitId])
  @@index([projectId])
}

model StoryBeat {
  id        String  @id @default(cuid())
  chapterId String
  type      String  // opening/conflict/turn/suspense
  content   String
  order     Int     @default(0)
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

// ─── Plot Lines & Plot Points (主线/支线剧情设计 & 剧情库) ───

model PlotLine {
  id          String      @id @default(cuid())
  projectId   String
  type        String      @default("main") // main(主线)/side(支线)
  title       String
  description String?
  order       Int         @default(0)
  color       String?     @default("#10b981") // Display color
  plotPoints  PlotPoint[]
  project     NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PlotPoint {
  id          String    @id @default(cuid())
  plotLineId  String
  targetLevel String    @default("unit") // volume/stage/unit/chapter
  targetId    String    // ID of the target entity (volume/stage/unit/chapter)
  order       Int       @default(0)
  title       String
  description String?
  status      String    @default("planned") // planned/writing/completed
  plotLine    PlotLine  @relation(fields: [plotLineId], references: [id], onDelete: Cascade)

  @@index([plotLineId])
  @@index([targetLevel, targetId])
}
